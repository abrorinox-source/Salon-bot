TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN

# Optional: set this to enable webhook mode (otherwise bot uses polling)
# Example: https://your-domain.com
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PORT=8080
TELEGRAM_WEBHOOK_LISTEN=0.0.0.0
# Optional custom path. If empty, bot token is used as path.
TELEGRAM_WEBHOOK_PATH=
# Render automatically sets PORT in production. If set, PORT has priority.
# PORT=10000
